{
    "name": "ftl-save-manager",
    "version": "1.0.0",
    "description": "Cross-platform save state manager for FTL and Multiverse",
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "build": "electron-builder"
    },
    "build": {
        "appId": "com.ftl.savemanager",
        "win": {
            "target": "portable"
        },
        "mac": {
            "target": "dmg"
        },
        "linux": {
            "target": "AppImage"
        }
    },
    "devDependencies": {
        "electron": "^30.0.0",
        "electron-builder": "^26.8.1"
    }
}